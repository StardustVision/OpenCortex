{
  "description": "OpenCortex memory hooks for Claude Code (cross-platform)",
  "note": "Uses node (guaranteed by Claude Code) to dispatch to bash (.sh) on macOS/Linux or PowerShell (.ps1) on Windows.",
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node ${CLAUDE_PLUGIN_ROOT}/hooks/hook_runner.mjs session-start",
            "timeout": 12
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node ${CLAUDE_PLUGIN_ROOT}/hooks/hook_runner.mjs user-prompt-submit",
            "timeout": 15
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node ${CLAUDE_PLUGIN_ROOT}/hooks/hook_runner.mjs stop",
            "async": true,
            "timeout": 120
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node ${CLAUDE_PLUGIN_ROOT}/hooks/hook_runner.mjs session-end",
            "timeout": 20
          }
        ]
      }
    ]
  }
}
