{
  "description": "OpenCortex memory hooks for Claude Code (cross-platform)",
  "note": "hook_runner.py auto-detects platform: bash (.sh) on macOS/Linux, PowerShell (.ps1) on Windows.",
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 ${CLAUDE_PLUGIN_ROOT}/hooks/hook_runner.py session-start",
            "timeout": 12
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 ${CLAUDE_PLUGIN_ROOT}/hooks/hook_runner.py user-prompt-submit",
            "timeout": 15
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 ${CLAUDE_PLUGIN_ROOT}/hooks/hook_runner.py stop",
            "async": true,
            "timeout": 120
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 ${CLAUDE_PLUGIN_ROOT}/hooks/hook_runner.py session-end",
            "timeout": 20
          }
        ]
      }
    ]
  }
}
